# Copy to .env (repo root) and edit. .env is gitignored — never commit real keys.
#
# Any OpenAI-compatible endpoint works: LiteLLM, vLLM, llama.cpp --api, Ollama's
# /v1 shim, or a hosted API. Point it at your own open-weights model.

# Base URL INCLUDING the /v1 suffix.
MOX_LLM_BASE_URL=http://localhost:4000/v1

# Bearer token for the endpoint (leave blank if it needs none).
MOX_LLM_API_KEY=

# Model name as your endpoint exposes it.
MOX_LLM_MODEL=gpt-oss-120b
